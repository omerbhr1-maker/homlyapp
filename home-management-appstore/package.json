{
  "name": "home-management",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:auth": "playwright test tests/auth.spec.ts",
    "test:house": "playwright test tests/house.spec.ts",
    "test:items": "playwright test tests/items.spec.ts",
    "test:search": "playwright test tests/search.spec.ts",
    "test:settings": "playwright test tests/settings.spec.ts",
    "test:profile": "playwright test tests/user-profile.spec.ts",
    "test:invite": "playwright test tests/invite.spec.ts",
    "test:sections": "playwright test tests/items-sections.spec.ts",
    "test:report": "playwright show-report",
    "sync": "../scripts/sync-web-to-appstore.sh",
    "sync:install": "../scripts/sync-web-to-appstore.sh --install --ios-sync",
    "ios:build": "npm run build && npm run sync:install",
    "ios:deploy": "npm run ios:build && cd ../home-management-appstore && npx cap open ios",
    "typecheck": "tsc --noEmit",
    "build:ios": "npm run build && npx cap sync ios",
    "ios:sync": "npx cap sync ios",
    "ios:open": "npx cap open ios"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
